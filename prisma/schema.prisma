datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  createdAt DateTime @default(now())
}

model Appointment {
  id        String   @id @default(cuid())
  date      DateTime
  status    String
  createdAt DateTime @default(now())
}
